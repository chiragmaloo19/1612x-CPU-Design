      <a name="text" val="ALU SELECTION SUBCIRCUIT"/>
    </comp>
    <comp lib="8" loc="(440,1495)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="cycle, allowing for smooth execution of operations within the CPU."/>
    </comp>
    <comp lib="8" loc="(625,1385)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="that determine which specific operation the ALU should perform, such as addition, subtraction, logical"/>
    </comp>
    <comp lib="8" loc="(625,1410)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="operations, or other arithmetic functions. These variables are generated by the sub-circuit based on the"/>
    </comp>
    <comp lib="8" loc="(635,1335)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="This sub-circuit generates selection variables for the ALU based on the timing signal playing a crucial role"/>
    </comp>
    <comp lib="8" loc="(645,1440)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="timing signal, which synchronizes the operation of the ALU with the overall system. By using timing signals,"/>
    </comp>
    <comp lib="8" loc="(650,1360)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="in controlling the operation of the Arithmetic Logic Unit (ALU). The selection variables act as control signals"/>
    </comp>
    <comp lib="8" loc="(650,1465)" name="Text">
      <a name="font" val="Segoe Print bold 20"/>
      <a name="text" val="the sub-circuit ensures that the ALU performs the correct operation at the right moment in the instruction"/>
    </comp>
    <comp lib="8" loc="(70,1335)" name="Text">
      <a name="font" val="Segoe Script bold 25"/>
      <a name="text" val="USE - "/>
    </comp>
